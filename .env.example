# =============================================================
# 苏超联赛直播分发中台 - 环境变量模板
# 复制为 .env 并填写真实值后执行 install.sh
# 标注 [必填] 的变量必须修改，[可选] 可留空
# =============================================================

# ---- 应用 ----------------------------------------------------------------
APP_ENV=production
# [可选] 后端 API 端口，默认 8080（install.sh 会自动写入）
APP_PORT=8080
# [必填] JWT 签名密钥，请使用随机长字符串（install.sh 会自动生成）
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ---- 前端端口 ------------------------------------------------------------
# [可选] 前端访问端口，默认 3080（install.sh 会自动写入）
FRONTEND_PORT=3080

# ---- SRS 端口 ------------------------------------------------------------
# [可选] RTMP 推流/拉流端口，默认 1935
RTMP_PORT=1935
# [可选] SRS HTTP API 端口，默认 1985
SRS_API_PORT=1985
# [可选] SRS HTTP 播放端口，默认 8088
SRS_HTTP_PORT=8088

# ---- 数据库（保持默认，数据存放在 Docker Volume 中）--------------------
DB_PATH=/app/data/db/susuper.db

# ---- 文件存储（保持默认）-----------------------------------------------
UPLOAD_DIR=/app/data/uploads
TRANSCODE_DIR=/app/data/transcoded
# 单个宣传片最大体积（MB）
MAX_UPLOAD_SIZE_MB=2048

# ---- SRS 内部连接（保持默认，容器网络自动对接）------------------------
SRS_HOST=srs
SRS_RTMP_PORT=1935

# ---- FFmpeg 转码参数（保持默认即可）-------------------------------------
FFMPEG_BIN=ffmpeg
TRANSCODE_CONCURRENCY=2
TRANSCODE_RESOLUTION=1920x1080
TRANSCODE_FPS=25
TRANSCODE_KEYFRAME_INTERVAL=50
TRANSCODE_AUDIO_BITRATE=128k
TRANSCODE_AUDIO_SAMPLERATE=44100

# ---- 熔断阈值（保持默认）-----------------------------------------------
# FFmpeg 进程连续失败 N 次后触发熔断告警
FFMPEG_MAX_RETRIES=3
FFMPEG_RETRY_DELAY_SECONDS=3

# ---- 短信告警 HTTP 网关（可选）-----------------------------------------
# 留空则禁用短信告警，系统仍会在界面内记录告警日志
# POST 请求体格式：{"key":"<SMS_API_KEY>","phones":["..."],"content":"..."}
SMS_API_URL=
SMS_API_KEY=
# 超管手机号，逗号分隔，触发熔断时发送
SMS_SUPER_ADMIN_PHONES=

# ---- 初始超管账号 -------------------------------------------------------
# [必填] 首次启动时自动创建超管账号 admin 的密码
# 启动后请立即通过界面修改密码
ADMIN_INITIAL_PASSWORD=Admin@2025!

# =============================================================
# 苏超联赛直播分发中台 - 环境变量模板
# 复制为 .env 并填写真实值
# =============================================================

# ---- 应用 ----
APP_ENV=production
APP_PORT=8080
JWT_SECRET=change_me_to_a_long_random_string_32chars

# ---- 数据库 ----
DB_PATH=/app/data/db/susuper.db

# ---- 文件存储 ----
UPLOAD_DIR=/app/data/uploads
TRANSCODE_DIR=/app/data/transcoded
# 单个宣传片最大体积（MB）
MAX_UPLOAD_SIZE_MB=2048

# ---- SRS 流媒体服务 ----
SRS_HOST=srs
SRS_RTMP_PORT=1935
SRS_API_PORT=1985
# SRS RTMP 内网基地址（后端 FFmpeg 推流用）
SRS_RTMP_BASE=rtmp://srs:1935

# ---- FFmpeg ----
FFMPEG_BIN=ffmpeg
TRANSCODE_CONCURRENCY=2
# 目标转码参数（离线标准化，保证与直播流格式对齐）
TRANSCODE_VIDEO_CODEC=libx264
TRANSCODE_VIDEO_PRESET=veryfast
TRANSCODE_VIDEO_PROFILE=main
TRANSCODE_RESOLUTION=1920x1080
TRANSCODE_FPS=25
TRANSCODE_KEYFRAME_INTERVAL=50   # 2 秒 GOP @ 25fps
TRANSCODE_AUDIO_CODEC=aac
TRANSCODE_AUDIO_BITRATE=128k
TRANSCODE_AUDIO_SAMPLERATE=44100

# ---- 进程守护 / 熔断 ----
FFMPEG_MAX_RETRIES=3
FFMPEG_RETRY_DELAY_SECONDS=3

# ---- 短信告警 HTTP 网关 ----
# 触发熔断后调用此 URL（POST JSON）
# 留空则禁用短信告警
SMS_API_URL=
SMS_API_KEY=
# 超管手机号（逗号分隔）
SMS_SUPER_ADMIN_PHONES=138xxxxxxxx,139xxxxxxxx

# ---- 初始超管账号 ----
ADMIN_INITIAL_PASSWORD=Admin@2025!
